{
  "name": "kanban-board",
  "displayName": "Kanban Board",
  "description": "A VSCode Kanban Board to manage tasks for your projects!",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kanban-board.openBoard",
        "title": "Open Kanban Board"
      },
      {
        "command": "kanban-board.openAsText",
        "title": "Open as Text",
        "icon": "$(file-text)"
      },
      {
        "command": "kanban-board.openAsKanban",
        "title": "Open as Kanban",
        "icon": "$(checklist)"
      }
    ],
    "customEditors": [
      {
        "viewType": "kanbanBoard.editor",
        "displayName": "Kanban Board",
        "selector": [
          {
            "filenamePattern": "**/todo.md"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "kanban-board.openAsKanban",
          "when": "resourceFilename == 'todo.md' && !activeCustomEditorId",
          "group": "navigation"
        },
        {
          "command": "kanban-board.openAsText",
          "when": "resourceFilename == 'todo.md' && activeCustomEditorId == 'kanbanBoard.editor'",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}