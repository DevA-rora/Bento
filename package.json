{
  "name": "bento",
  "displayName": "Bento",
  "description": "A VS Code Kanban Board to manage tasks for your projects!",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "kanban",
    "todo",
    "markdown",
    "productivity",
    "board"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DevA-rora/kanban-board-vscode.git"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bento.openBoard",
        "title": "Open Bento Board"
      },
      {
        "command": "bento.openAsText",
        "title": "Open as Text",
        "icon": "$(file-text)"
      },
      {
        "command": "bento.openAsKanban",
        "title": "Open as Bento",
        "icon": "$(checklist)"
      }
    ],
    "customEditors": [
      {
        "viewType": "bento.editor",
        "displayName": "Bento Board",
        "selector": [
          {
            "filenamePattern": "**/todo.md"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "bento.openAsKanban",
          "when": "resourceFilename == 'todo.md' && !activeCustomEditorId",
          "group": "navigation"
        },
        {
          "command": "bento.openAsText",
          "when": "resourceFilename == 'todo.md' && activeCustomEditorId == 'bento.editor'",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}